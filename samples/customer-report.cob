       IDENTIFICATION DIVISION.
       PROGRAM-ID. CUSTOMER-REPORT.
       AUTHOR. LEGACY-TEAM.

       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT CUSTOMER-FILE ASSIGN TO "CUSTFILE.DAT"
               ORGANIZATION IS LINE SEQUENTIAL.
           SELECT REPORT-FILE ASSIGN TO "CUSTRPT.DAT"
               ORGANIZATION IS LINE SEQUENTIAL.

       DATA DIVISION.
       FILE SECTION.
       FD  CUSTOMER-FILE.
       01  CUSTOMER-RECORD.
           05  CUST-ID            PIC 9(6).
           05  CUST-NAME          PIC X(30).
           05  CUST-SSN           PIC 9(9).
           05  CUST-ADDRESS       PIC X(50).
           05  CUST-BALANCE       PIC S9(7)V99.
           05  CUST-CREDIT-LIMIT  PIC 9(7)V99.
           05  CUST-ACCOUNT-TYPE  PIC X(2).

       FD  REPORT-FILE.
       01  REPORT-RECORD          PIC X(132).

       WORKING-STORAGE SECTION.
       01  WS-FLAGS.
           05  WS-EOF-FLAG        PIC X VALUE "N".
               88  WS-EOF         VALUE "Y".
           05  WS-ERROR-FLAG      PIC X VALUE "N".
               88  WS-ERROR       VALUE "Y".

       01  WS-COUNTERS.
           05  WS-READ-COUNT      PIC 9(6) VALUE 0.
           05  WS-WRITE-COUNT     PIC 9(6) VALUE 0.
           05  WS-ERROR-COUNT     PIC 9(4) VALUE 0.

       01  WS-TOTALS.
           05  WS-TOTAL-BALANCE   PIC S9(9)V99 VALUE 0.
           05  WS-TOTAL-CREDIT    PIC 9(9)V99 VALUE 0.

       01  WS-WORK-FIELDS.
           05  WS-FORMATTED-BAL   PIC -ZZZ,ZZZ,ZZ9.99.
           05  WS-CURRENT-DATE    PIC X(10).

       PROCEDURE DIVISION.
       MAIN-PROGRAM.
           PERFORM INITIALIZE-PROGRAM
           PERFORM PROCESS-RECORDS UNTIL WS-EOF
           PERFORM FINALIZE-PROGRAM
           STOP RUN.

       INITIALIZE-PROGRAM.
           OPEN INPUT CUSTOMER-FILE
           OPEN OUTPUT REPORT-FILE
           MOVE FUNCTION CURRENT-DATE TO WS-CURRENT-DATE
           DISPLAY "CUSTOMER REPORT STARTED: " WS-CURRENT-DATE
           PERFORM READ-CUSTOMER.

       READ-CUSTOMER.
           READ CUSTOMER-FILE
               AT END SET WS-EOF TO TRUE
               NOT AT END ADD 1 TO WS-READ-COUNT
           END-READ.

       PROCESS-RECORDS.
           EVALUATE TRUE
               WHEN CUST-BALANCE > CUST-CREDIT-LIMIT
                   PERFORM HANDLE-OVER-LIMIT
               WHEN CUST-BALANCE < 0
                   PERFORM HANDLE-NEGATIVE-BALANCE
               WHEN OTHER
                   PERFORM WRITE-NORMAL-RECORD
           END-EVALUATE
           ADD CUST-BALANCE TO WS-TOTAL-BALANCE
           ADD CUST-CREDIT-LIMIT TO WS-TOTAL-CREDIT
           PERFORM READ-CUSTOMER.

       HANDLE-OVER-LIMIT.
           MOVE CUST-BALANCE TO WS-FORMATTED-BAL
           DISPLAY "OVER LIMIT: " CUST-NAME " BAL=" WS-FORMATTED-BAL
           ADD 1 TO WS-ERROR-COUNT
           PERFORM WRITE-ERROR-RECORD.

       HANDLE-NEGATIVE-BALANCE.
           DISPLAY "NEGATIVE BALANCE: " CUST-NAME
           ADD 1 TO WS-ERROR-COUNT
           PERFORM WRITE-ERROR-RECORD.

       WRITE-NORMAL-RECORD.
           MOVE CUST-BALANCE TO WS-FORMATTED-BAL
           WRITE REPORT-RECORD FROM CUSTOMER-RECORD
           ADD 1 TO WS-WRITE-COUNT.

       WRITE-ERROR-RECORD.
           WRITE REPORT-RECORD FROM CUSTOMER-RECORD
           ADD 1 TO WS-WRITE-COUNT.

       FINALIZE-PROGRAM.
           DISPLAY "RECORDS READ:    " WS-READ-COUNT
           DISPLAY "RECORDS WRITTEN: " WS-WRITE-COUNT
           DISPLAY "ERRORS FOUND:    " WS-ERROR-COUNT
           MOVE WS-TOTAL-BALANCE TO WS-FORMATTED-BAL
           DISPLAY "TOTAL BALANCE:   " WS-FORMATTED-BAL
           CLOSE CUSTOMER-FILE
           CLOSE REPORT-FILE
           CALL "AUDIT-LOG" USING WS-READ-COUNT WS-WRITE-COUNT.
